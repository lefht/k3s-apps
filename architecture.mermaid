graph TB
    subgraph GitHub["GitHub"]
        repo["lefht/k3s-apps<br/>Kubernetes Manifests"]
    end

    subgraph Proxmox["Proxmox Server"]
        subgraph k3s["k3s Cluster"]
            subgraph server["kiwi - Control Plane<br/>10.10.1.240"]
                api["K3s API Server"]
                argocd["ArgoCD"]
            end

            subgraph worker1["lime - Worker Node"]
                pod1["nginx pod"]
            end

            subgraph worker2["fig - Worker Node"]
                pod2["nginx pod"]
            end
        end
    end

    repo -- "GitOps Sync" --> argocd
    argocd -- "Deploy" --> pod1
    argocd -- "Deploy" --> pod2
    api -.- worker1
    api -.- worker2

    style GitHub fill:#24292e,color:#fff
    style repo fill:#333,color:#fff
    style Proxmox fill:#e86b1a,color:#fff
    style k3s fill:#ffc61a,color:#333
    style server fill:#4a90d9,color:#fff
    style worker1 fill:#5cb85c,color:#fff
    style worker2 fill:#5cb85c,color:#fff
    style api fill:#326ce5,color:#fff
    style argocd fill:#ef7b4d,color:#fff
    style pod1 fill:#fff,color:#333
    style pod2 fill:#fff,color:#333
